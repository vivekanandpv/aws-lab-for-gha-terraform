            "json": "{\n  \"Version\": \"2012-10-17\",\n  \"Statement\": [\n    {\n      \"Sid\": \"GetEcrAuthorizationToken\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ecr:GetAuthorizationToken\",\n      \"Resource\": \"*\"\n    },\n    {\n      \"Sid\": \"PushOnlyOwnRepository\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ecr:UploadLayerPart\",\n        \"ecr:PutImage\",\n        \"ecr:InitiateLayerUpload\",\n        \"ecr:GetDownloadUrlForLayer\",\n        \"ecr:CompleteLayerUpload\",\n        \"ecr:BatchGetImage\",\n        \"ecr:BatchCheckLayerAvailability\"\n      ],\n      \"Resource\": \"arn:aws:ecr:ap-south-1:750819667599:repository/training/student01\"\n    },\n    {\n      \"Sid\": \"InvokeOwnDeploymentDocumentOnCalvin\",\n      \"Effect\": \"Allow\",\n      \"Action\": \"ssm:SendCommand\",\n      \"Resource\": [\n        \"arn:aws:ssm:ap-south-1:750819667599:document/grand-calvin-deploy-student01\",\n        \"arn:aws:ec2:ap-south-1:750819667599:instance/i-0a9acde77c21e3c7d\"\n      ]\n    },\n    {\n      \"Sid\": \"ReadCommandResult\",\n      \"Effect\": \"Allow\",\n      \"Action\": [\n        \"ssm:ListCommandInvocations\",\n        \"ssm:GetCommandInvocation\"\n      ],\n      \"Resource\": \"*\"\n    }\n  ]\n}",
