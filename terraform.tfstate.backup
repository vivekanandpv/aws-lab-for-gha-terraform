            "tags_all": {
              "Environment": "training",
              "ManagedBy": "Terraform",
              "Name": "grand-calvin",
              "Project": "grand-calvin",
              "Role": "shared-docker-host"
            },
            "tenancy": "default",
            "timeouts": null,
            "user_data": "#!/bin/bash\nset -euxo pipefail\n\ndnf update -y\ndnf install -y docker awscli jq util-linux\nsystemctl enable --now docker\n\nif ! systemctl list-unit-files amazon-ssm-agent.service \u003e/dev/null 2\u003e\u00261; then\n  dnf install -y amazon-ssm-agent || true\nfi\n\nsystemctl enable --now amazon-ssm-agent\n\nmkdir -p /opt/calvin/bin /opt/calvin/locks /var/log/calvin\n\ninstall -d -m 0755 /opt/calvin/bin\n\ncat \u003e/opt/calvin/bin/deploy-student \u003c\u003c'SCRIPT'\n#!/bin/bash\nset -euo pipefail\n\nSTUDENT_ID=\"${1:-}\"\nIMAGE_URI=\"${2:-}\"\nHOST_PORT=\"${3:-}\"\nAWS_REGION=\"ap-south-1\"\n\nif [[ ! \"$STUDENT_ID\" =~ ^student([0-2][0-9]|30)$ ]]; then\n  echo \"Invalid student ID: $STUDENT_ID\" \u003e\u00262\n  exit 10\nfi\n\nif [[ ! \"$HOST_PORT\" =~ ^81(0[1-9]|[12][0-9]|30)$ ]]; then\n  echo \"Invalid assigned port: $HOST_PORT\" \u003e\u00262\n  exit 11\nfi\n\nif [[ ! \"$IMAGE_URI\" =~ ^[0-9]{12}\\.dkr\\.ecr\\.ap-south-1\\.amazonaws\\.com/training/student[0-9]{2}:[A-Za-z0-9._-]+$ ]]; then\n  echo \"Invalid ECR image URI\" \u003e\u00262\n  exit 12\nfi\n\nEXPECTED_REPOSITORY=\"training/$STUDENT_ID\"\nif [[ \"$IMAGE_URI\" != *\"/$EXPECTED_REPOSITORY:\"* ]]; then\n  echo \"Image does not belong to $STUDENT_ID\" \u003e\u00262\n  exit 13\nfi\n\nCONTAINER_NAME=\"${STUDENT_ID}-app\"\nREGISTRY=\"${IMAGE_URI%%/*}\"\nLOCK_FILE=\"/opt/calvin/locks/${STUDENT_ID}.lock\"\n\nexec 9\u003e\"$LOCK_FILE\"\nflock -n 9 || {\n  echo \"Another deployment is already running for $STUDENT_ID\" \u003e\u00262\n  exit 14\n}\n\naws ecr get-login-password --region \"$AWS_REGION\" |\n  docker login --username AWS --password-stdin \"$REGISTRY\"\n\ndocker pull \"$IMAGE_URI\"\ndocker rm -f \"$CONTAINER_NAME\" 2\u003e/dev/null || true\n\ndocker run -d \\\n  --name \"$CONTAINER_NAME\" \\\n  --restart unless-stopped \\\n  --memory 512m \\\n  --memory-swap 512m \\\n  --cpus 0.50 \\\n  --pids-limit 256 \\\n  --read-only \\\n  --tmpfs /tmp:rw,noexec,nosuid,size=64m \\\n  --security-opt no-new-privileges:true \\\n  -e JAVA_TOOL_OPTIONS=\"-Xms128m -Xmx256m\" \\\n  -e STUDENT_ID=\"$STUDENT_ID\" \\\n  -p \"${HOST_PORT}:8080\" \\\n  \"$IMAGE_URI\"\n\nsleep 5\n\nif ! docker inspect --format '{{.State.Running}}' \"$CONTAINER_NAME\" | grep -q '^true$'; then\n  docker logs --tail 100 \"$CONTAINER_NAME\"\n  exit 15\nfi\n\ndocker image prune -f\n\necho \"Successfully deployed $STUDENT_ID on port $HOST_PORT\"\nSCRIPT\n\nchmod 0755 /opt/calvin/bin/deploy-student\n",
            "user_data_base64": null,
            "user_data_replace_on_change": true,
            "volume_tags": null,
